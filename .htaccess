# ============================================================
# Güvenlik
# ============================================================

# 1. Dizin listeleme kapat
Options -Indexes

# 5. Sunucu imzası gizle
ServerSignature Off

# 4. HTTP güvenlik başlıkları
<IfModule mod_headers.c>
    # Clickjacking: siteyi iframe içine almayı engeller
    Header always set X-Frame-Options "SAMEORIGIN"
    # MIME sniffing saldırılarını engeller
    Header always set X-Content-Type-Options "nosniff"
    # Referer bilgisini yalnızca aynı origin'e gönderir
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HTTPS zorunluluğunu tarayıcıya bildirir (1 yıl)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# 3. Hassas dosyalara erişimi engelle
<FilesMatch "(^\.env|\.gitignore|composer\.json|composer\.lock)$">
    Require all denied
</FilesMatch>

# ============================================================
# Performans & Cache
# ============================================================

# 6. GZIP sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 7. Cache — görseller ve stil dosyaları (30 gün)
<FilesMatch "\.(jpg|jpeg|png|gif|css|js)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

# 7. Cache — fontlar ve ikonlar (1 yıl)
<FilesMatch "\.(woff|woff2|ttf|eot|svg|ico)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
</FilesMatch>

# ============================================================
# Yönlendirme
# ============================================================

RewriteEngine On

# 2. iSystem/ klasörüne doğrudan URL erişimini engelle
# THE_REQUEST orijinal HTTP isteğini içerir; dahili RewriteRule yeniden yazmalarını etkilemez.
RewriteCond %{THE_REQUEST} \s/iSystem/ [NC]
RewriteRule ^ - [F,L]

# 3. Gizli dosya ve klasörlere erişimi engelle (.git, .env vb.)
# .well-known dizinine izin verilir (Let's Encrypt / SSL doğrulaması)
RewriteRule (^|/)\.(?!well-known) - [F,L]

# HTTPS değilse yönlendir
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www'li ise www'suz hale yönlendir
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# 8. Özel hata sayfaları
ErrorDocument 404 /error.php
ErrorDocument 403 /error.php

# ============================================================
# Sayfa Yönlendirme
# ============================================================

# 9. [NC] ile büyük/küçük harf duyarsız tek kural
RewriteRule ^developer(/.*)?$  iSystem/iDeveloper.php  [L,QSA,NC]
RewriteRule ^localapi(/.*)?$   iSystem/iPage_System.php [L,QSA,NC]
RewriteRule ^timezoneset(/.*)?$ index.php?s=timezoneset [L,QSA]

# SEO için sayfaları yönlendirme
RewriteRule ^home(/.*)?$             index.php?s=home             [L]
RewriteRule ^media(/.*)?$            index.php?s=media            [L]
RewriteRule ^howto(/.*)?$            index.php?s=howto            [L]
RewriteRule ^tutorials(/.*)?$        index.php?s=tutorials        [L]
RewriteRule ^thegame(/.*)?$          index.php?s=thegame          [L]
RewriteRule ^characterclasses(/.*)?$ index.php?s=characterclasses [L]
RewriteRule ^empires(/.*)?$          index.php?s=empires          [L]
RewriteRule ^login(/.*)?$            index.php?s=login            [L,QSA]
RewriteRule ^profil(/.*)?$           index.php?s=profil           [L]
RewriteRule ^pwchange(/.*)?$         index.php?s=pwchange         [L]
RewriteRule ^characters(/.*)?$       index.php?s=characters       [L]
RewriteRule ^accrecover(/.*)?$       index.php?s=accrecover       [L]
RewriteRule ^logout(/.*)?$           index.php?s=logout           [L]
RewriteRule ^register(/.*)?$         index.php?s=register         [L,QSA]
RewriteRule ^registerlog(/.*)?$      index.php?s=registerlog      [L,QSA]
RewriteRule ^singup(/.*)?$           index.php?s=register         [L,QSA]
RewriteRule ^forgotpassword(/.*)?$   index.php?s=forgotpassword   [L,QSA]
RewriteRule ^passwordlost(/.*)?$     index.php?s=passwordlost     [L,QSA]
RewriteRule ^download$               index.php?s=download         [L]
RewriteRule ^rankplayer$             index.php?s=rankings         [L]
RewriteRule ^rankguild$              index.php?s=guildrank        [L]
